                                                {{else}}
                                                -
                                                {{/if}}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="quotation-details-section">
                        <table class="quotation-details-table">
                            <tr>
                                <td>Quote No:</td>
                                <td>{{invoice_no}}</td>
                            </tr>
                            <tr>
                                <td>Date:</td>
                                <td><span class="date-format" data-date="{{doc_date}}"></span></td>
                            </tr>
                            <tr>
                                <td>Due Date:</td>
                                <td><span class="date-format" data-date="{{due_date}}"></span></td>
                            </tr>
                            <tr>
                                <td>Ref No:</td>
                                <td>{{ref_1}}</td>
                            </tr>
                            <tr>
                                <td>Currency/Rate:</td>
                                <td>{{currency.code}} / {{#if exchange_rate}}{{exchange_rate}}{{else}}1{{/if}}</td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <div style="height: 15px;"></div>

            <!-- Items Table -->

            <div class="items-table-wrapper" style="min-height: 452px;">
                <table class="items-table">
                    <thead>
                        <tr>
                            <th style="width: 5%;">#</th>
                            <th>Stone</th>
                            <th>Shape</th>
                            <th>Size</th>
                            <th>Color</th>
                            <th>Cutting</th>
                            <th>Clarity</th>
                            <th class="text-right">Pcs</th>
                            <th class="text-right">Weight(cts)</th>
                            <th class="text-right">Price/Unit</th>
                            <th class="text-right">Disc(%)</th>
                            <th class="text-right" style="width: 15%;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each items}}
                        <tr>
                            <td>{{inc @index}}</td>
                            <td>{{stone}}</td>
                            <td>{{shape}}</td>
                            <td>{{size}}</td>
                            <td>{{color}}</td>
                            <td>{{cutting}}</td>
                            <td>{{clarity}}</td>
                            <td class="text-right">{{pcs}}</td>
                            <td class="text-right">{{weight}}</td>
                            <td class="text-right">{{price}}</td>
                            <td class="text-right">{{discount_percent}}%</td>
                            <td class="text-right">{{amount}} USD</td>
                        </tr>
                        {{#if remark}}
                        <tr class="remark-row">
                            <td></td>
                            <td colspan="11">
                                <span class="remark-label">Remark:</span> {{remark}}
                            </td>
                        </tr>
                        {{/if}}
                        {{/each}}
                    </tbody>
                </table>

            </div>

            <!-- Subtotal Strip (Under table like in design) -->
            <table class="subtotal-table">
                <tr>
                    <td style="width: 50%; text-align: left;">Total</td>
                    <td style="text-align: right;">{{summary.total_pcs}}</td>
                    <td style="text-align: right;">{{summary.total_weight}}</td>
                    <td style="width: 25%;"></td> <!-- Spacer for Price/Disc cols -->
                    <td style="text-align: right; width: 15%;">{{summary.sub_total}} {{currency.code}}</td>
                </tr>
            </table>

            <!-- Summary & Notes -->
            <div class="summary-wrapper">
                <div class="note-section">
                    <div class="note-title">Note</div>
                    <div class="note-content">
                        <!-- Static note or dynamic if available -->
                        {{#if note}}{{note}}{{else}}Standard Terms and Conditions Apply.{{/if}}
                    </div>
                </div>

                <div class="summary-totals">
                    <div class="summary-row">
                        <span>Discount</span>
                        <span>{{summary.discount}} {{currency.code}}</span>
                    </div>
                    <div class="summary-row bold">
                        <span>Amount</span>
                        <span>{{summary.total_after_discount}} {{currency.code}}</span>
                    </div>
                    <div class="summary-row">
                        <span>VAT {{#if summary.vat}}{{summary.vat}}{{else}}7{{/if}}%</span>
                        <span>{{#if summary.vat_amount}}{{summary.vat_amount}}{{else}}0.00{{/if}}
                            {{currency.code}}</span>
                    </div>
                    <div class="summary-row">
                        <span>Other Charges</span>
                        <span>{{#if summary.other_charge}}{{summary.other_charge}}{{else}}0.00{{/if}}
                            {{currency.code}}</span>
                    </div>
                    <div class="summary-row total-row">
                        <span>Grand Total</span>
                        <span>{{summary.grand_total}} {{currency.code}}</span>
                    </div>
                </div>
            </div>

        </div> <!-- End Content Wrapper -->

        <!-- Footer/Signatures -->
        <div class="footer-main">
            <table class="signatures-table">
                <tr>
                    <td>
                        <div class="signature-space"></div>
                        <div class="signature-line">Prepared By</div>
                    </td>
                    <td>
                        <div class="signature-space"></div>
                        <div class="signature-line">Approved By</div>
                    </td>
                    <td>
                        <div class="signature-space"></div>
                        <div class="signature-line">Received By</div>
                    </td>
                </tr>
            </table>

            <table class="footer-table" style="margin-top: 10px;">
                <tr>
                    <td>© 2024 {{companyProfile.company_name}}</td>
                    <td class="text-right">
                        Generated by ERP System - {{doc_date}}
                    </td>
                </tr>
            </table>
        </div>

    </div>

    <script>
        // Initialize Barcode
        document.addEventListener("DOMContentLoaded", function () {
            JsBarcode("#barcode-quote", "{{invoice_no}}", {
                format: "CODE128",
                width: 1.2,
                height: 30,
                displayValue: false,
                margin: 0,
            });

            // Date Formatting helper (simple JS approach for the rendered HTML)
            const dateElements = document.querySelectorAll(".date-format");
            dateElements.forEach(el => {
                const rawDate = el.getAttribute('data-date');
                if (rawDate) {
                    const d = new Date(rawDate);
                    if (!isNaN(d.getTime())) {
                        el.textContent = d.toLocaleDateString('en-GB'); // DD/MM/YYYY format
                    } else {
                        el.textContent = rawDate;
                    }
                }
            });

            // Fix relative image paths for Puppeteer if backend base URL is missing
            const images = document.querySelectorAll('img');
            images.forEach(img => {
                const src = img.getAttribute('src');
                if (src && src.startsWith('/')) {
                    // Attempt to make it absolute if you know the port, or just log it
                    // Assuming backend serves static files on the same port/domain
                    // In Puppeteer (file://), this might be tricky. 
                    // Ideally backend converts to base64.
                    // As a fallback, we can try to point to a known dev server or just leave it.
                    // img.src = 'http://localhost:5000' + src; 
                }

                img.onerror = function () {
                    this.style.display = 'none';
                    // Optional: show placeholder text
                    // this.parentNode.innerHTML = '<span style="font-size:10px; color:red;">Img Err</span>';
                };
            });
        });
    </script>
</body>

</html>