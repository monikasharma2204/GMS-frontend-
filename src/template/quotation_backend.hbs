                                        {{companyProfile.email}}
                                    </span>
                                </div>

                                <div class="company-details-item">Tax ID: {{companyProfile.tax_id}}</div>
                            </div>
                        </div>
                    </td>
                    <td class="quotation-title-cell">
                        <div class="quotation-title">Quotation</div>
                        <div>
                            <svg id="barcode-quote" class="barcode-image"></svg>
                        </div>
                    </td>
                </tr>
            </table>

            <hr />

