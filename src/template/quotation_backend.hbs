<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quotation - {{invoice_no}}</title>
    <!-- pdf library (optional if using puppeteer, but good for styling consistency) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;600;700&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Noto Sans", sans-serif;
            color: #2a2a2a;
            background: #f5f5f5;
            margin: 0;
        }

        /* Main Container - A4 size */
        .main-container {
            width: 794px;
            /* A4 width at 96 DPI */
            background: #fff;
            margin: auto;
            padding: 32px;
            position: relative;
            box-sizing: border-box;
            page-break-after: avoid;
            page-break-inside: avoid;
            display: flex;
            flex-direction: column;
            min-height: 1123px;
            /* Ensure full A4 height */
        }

        /* Table-based layout styles */
        .layout-table,
        .header-table,
        .details-table,
        .items-table,
        .summary-container-table,
        .signatures-table,
        .footer-table {
            width: 100%;
            border-collapse: collapse;
            border-spacing: 0;
        }

        td {
            vertical-align: top;
        }

        /* Header Section */
        .logo-cell {
            width: 22%;
            vertical-align: middle;
            padding-right: 20px;
        }

        .logo-cell img {
            max-width: 100%;
            max-height: 85px;
            object-fit: contain;
        }

        .company-details {
            padding-left: 8px;
            color: #706f6f;
            line-height: normal;
            margin-top: -7px;
            border-left: 1px solid #ededed;
            width: 280px;
            /* Increased slightly for flexibility */
        }

        .company-name {
            font-size: 9px;
            font-weight: 600;
            color: #2a2a2a;
            margin-bottom: 6px;
        }

        .company-details-item {
            display: block;
            font-size: 9px;
            font-weight: 400;
            margin-bottom: 4px;
        }

        .company-address {
            display: flex;
            gap: 8px;
            margin-bottom: 4px;
        }

        .address-img svg,
        .phone-email-item svg {
            width: 12px;
            height: 12px;
        }

        .phone-email {
            display: flex;
            flex-direction: column;
            /* Stacked for better fit */
            gap: 4px;
        }

        .quotation-title-cell {
            text-align: right;
            vertical-align: top;
        }

        .quotation-title {
            font-size: 20px;
            font-weight: 600;
            color: #1e1e1e;
            line-height: normal;
        }

        .barcode-image {
            width: auto;
            height: 37px;
            margin-top: 5px;
        }

        .phone-email-item {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        hr {
            height: 1px;
            border: none;
            background-color: #ededed;
            margin: 14px 0px;
            width: 100%;
        }

        /* Customer & Info Section */
        .customer-section {
            width: 50%;
            padding-right: 15px;
        }

        .customer-section-inner {
            border: 1px solid #ededed;
            position: relative;
            padding: 12px 10px;
            border-radius: 4px;
            height: 100%;
        }

        .customer-title {
            font-size: 10px;
            color: #706f6f;
            background-color: #fff;
            position: absolute;
            top: -7px;
            left: 10px;
            font-weight: 400;
            padding: 0 4px;
        }

        .customer-name {
            font-size: 9px;
            font-weight: 600;
            color: #1e1e1e;
            margin-bottom: 4px;
        }

        .quotation-details-section {
            width: 50%;
            text-align: right;
        }

        .items-table tbody {
            vertical-align: top;
        }

        .quotation-details-table {
            width: 100%;
            max-width: 300px;
            margin-left: auto;
        }

        .quotation-details-table td {
            padding: 3px 0;
        }

        .quotation-details-table td:first-child {
            text-align: left;
            font-size: 9px;
            font-weight: 600;
            color: #706f6f;
        }

        .quotation-details-table td:last-child {
            text-align: right;
            color: #706f6f;
            font-size: 9px;
            font-weight: 400;
        }

        /* Items Table */
        .items-table {
            margin-bottom: 6px;
        }

        .items-table th {
            padding: 8px 4px;
            text-align: left;
            font-size: 9px;
            font-weight: 600;
            color: #1e1e1e;
            background: #f3f3f3;
        }

        .items-table td {
            padding: 6px 4px;
            text-align: left;
            font-size: 9px;
            font-weight: 400;
            color: #706f6f;
            border-bottom: 1px solid #e6e6e6;
        }

        /* Alignment Helper Classes */
        .text-right {
            text-align: right !important;
        }

        .text-center {
            text-align: center !important;
        }

        .text-left {
            text-align: left !important;
        }

        .items-table th:last-child,
        .items-table td:last-child {
            text-align: right;
        }

        /* Remark Row */
        .remark-row td {
            border-bottom: 1px solid #e6e6e6;
            padding-top: 0;
            padding-bottom: 8px;
            color: #666;
            font-size: 8px;
            font-style: italic;
        }

        .remark-label {
            font-weight: 600;
            color: #111;
            margin-right: 4px;
        }

        /* Subtotals at bottom of table */
        .subtotal-table {
            width: 100%;
            background-color: #f3f3f3;
            margin-bottom: 8px;
        }

        .subtotal-table td {
            padding: 6px 4px;
            font-size: 9px;
            font-weight: 700;
            color: #1e1e1e;
        }

        /* Summary Section */
        .summary-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-top: 18px;
        }

        .note-section {
            width: 60%;
            border: 1px solid #ededed;
            border-radius: 4px;
            padding: 8px;
            min-height: 80px;
        }

        .note-title {
            font-size: 10px;
            color: #706f6f;
            margin-bottom: 4px;
        }

        .note-content {
            font-size: 9px;
        }

        .summary-totals {
            width: 35%;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            margin-bottom: 4px;
            color: #1e1e1e;
        }

        .summary-row.bold {
            font-weight: 600;
        }

        .summary-row.total-row {
            border-top: 1px solid #d2d2d2;
            border-bottom: 1px solid #d2d2d2;
            padding: 6px 0;
            margin-top: 6px;
            font-weight: 700;
            font-size: 11px;
        }

        /* Signatures */
        .signatures-table {
            margin-top: 40px;
        }

        .signatures-table td {
            text-align: center;
            width: 33%;
            vertical-align: bottom;
        }

        .signature-line {
            border-top: 1px solid #ededed;
            width: 80%;
            margin: auto;
            padding-top: 4px;
            font-size: 9px;
            color: #1e1e1e;
        }

        .signature-space {
            height: 40px;
        }

        /* Footer */
        .footer-main {
            margin-top: auto;
            padding-top: 10px;
        }

        .footer-table td {
            font-size: 9px;
            color: #706f6f;
        }

        @media print {
            @page {
                size: A4;
                margin: 0;
            }

            body {
                background: #fff;
            }

            .main-container {
                width: 100%;
                box-shadow: none;
                padding: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="main-container">
        <!-- Content Wrapper to push footer down -->
        <div style="flex: 1;">

            <!-- Header -->
            <table class="header-table">
                <tr>
                    <td class="logo-cell">
